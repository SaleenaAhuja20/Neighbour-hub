generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  fullName  String
  email     String     @unique
  password  String
  role      Role       @default(RESIDENT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  status    UserStatus @default(ACTIVE)
  bookings  Booking[]  @relation("ResidentBookings")
  provider  Provider?
}

model Provider {
  id           String    @id @default(cuid())
  userId       String    @unique
  serviceTitle String
  category     String
  experience   String
  phone        String
  address      String
  description  String
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  serviceFee   Int       @default(0)
  bookings     Booking[]
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String        @id @default(cuid())
  residentId  String
  providerId  String
  bookingDate DateTime
  address     String
  notes       String?
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  bookingTime String
  provider    Provider      @relation(fields: [providerId], references: [id])
  resident    User          @relation("ResidentBookings", fields: [residentId], references: [id])
}

enum Role {
  RESIDENT
  PROVIDER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}
