generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RESIDENT
  PROVIDER
  MODERATOR
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  role      Role     @default(RESIDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}